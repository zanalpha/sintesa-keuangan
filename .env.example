# Salin file ini menjadi .env untuk menjalankan di komputer lokal.
# Di Render, isi variabel ini lewat dashboard (Environment) — JANGAN commit file .env asli.

# Koneksi database Postgres.
# - Di lokal: boleh dikosongkan → aplikasi memakai database sementara di memori (data hilang saat server mati).
# - Di Render: otomatis terisi dari database yang dibuat oleh render.yaml.
DATABASE_URL=

# Kunci rahasia untuk mengamankan sesi login. WAJIB diisi string acak panjang di produksi.
# Contoh membuat: buka terminal, ketik:  node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=ganti-dengan-string-acak-yang-panjang

# Port server (Render mengisinya otomatis). Default 3000 saat lokal.
PORT=3000
